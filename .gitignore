# 党建益友 monorepo 根级 gitignore
# react/ 和 backend/ 各自有自己的 .gitignore 处理子项目特定文件

# Node deps (新加的 root package.json 装了 husky)
node_modules/

# 3D 展厅客户端构建产物(public/env 的 HDR 与后端字体 TTF 要提交,勿忽略)
exhibition-client/dist/

# Husky 自动生成的工具脚本(由 npm install 触发的 husky init 重建)
# 但保留 .husky/pre-commit 和其他用户编写的 hook
.husky/_/

# OS
.DS_Store
Thumbs.db

# Editor
.idea/
.vscode/
*.swp

# Claude Code IDE 状态
.claude/

# 本地参考/备份资料(不纳入版本管理)
/荣誉系统.md
/产品功能自我记录/
/功能参考文件夹/
/回滚备份-2026-05-23/

# 临时数据 dump(xlsx 调试导出,不纳入版本管理)
/xlsx_dump*.txt

# 群晖发布:历史存档与本机 NAS 连接配置(含用户名,不入库)
deploy/releases/
deploy/synology/release.config.json

# 用户放置的待入库头像原图(经头像库批量入库,不进 git)
/avatars/
