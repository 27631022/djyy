// 党建益友 平台底座 Prisma Schema
//
// 2026-07-03 起开发/生产统一 PostgreSQL(本地 = D:\web\pg10-portable 便携版,
// 群晖生产 = postgres:16 容器)。开发期 PG10 比生产更旧,天然兜住将来
// 信创库(瀚高/金仓,内核≈PG10)的兼容性。
// 注意:模型延续「避开 enum / array / native JSON」的约定 —— JSON 一律存 String
// 列由应用解析,保证任何 PG 系国产库都能跑;新表别引入原生 JSON/enum。

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ─────────────────────────────────────────────────────────
// 组织 (双体系并行:党组织 + 行政机构,各自支持真实组织与虚拟组织)
// ─────────────────────────────────────────────────────────
// kind 取值:
//   party       党组织
//   admin       行政机构
//
// type 在 kind 范围内取值:
//   kind=party : committee(党委) | general(党总支) | branch(党支部) | group(党小组)
//   kind=admin : corp(集团) | company(公司) | dept(部门) | team(班组)
//
// isVirtual:
//   false (默认)  实体组织,层级隶属固定,人员归属相对稳定
//   true          虚拟组织 (专班/项目组/学习小组等),临时性、跨部门、人员可灵活进出
//
// 一个用户可以同时归属任意多个组织 (含虚拟和真实),由 UserOrganization 表的复合主键
// [userId, orgId] 保证唯一性。isPrimary 标记其主归属。
// @module: organization
model Organization {
  id        String         @id @default(cuid())
  name      String // 简称 — 列表 / 树视图日常显示
  fullName  String? // 全称 — 证书 / 公文 / 印章等正式场合需要(可空兼容老数据)
  code      String         @unique
  kind      String // party | admin
  type      String // 见上方注释(层级:level1~4 单位 / 党组织类型)—— 与 isDept 正交
  isVirtual Boolean        @default(false) // 虚拟组织标记
  isDept    Boolean        @default(false) // 部门标记:勾上 = 单位内部职能部门(非层级单位);与 type 层级正交,对口责任部门只能选 isDept=true
  parentId  String?
  parent    Organization?  @relation("OrgTree", fields: [parentId], references: [id])
  children  Organization[] @relation("OrgTree")
  sortOrder Int            @default(0)
  active    Boolean        @default(true)
  meta      String? // 扩展字段 JSON 串 (SQLite 无原生 JSON)
  createdAt DateTime       @default(now())
  updatedAt DateTime       @updatedAt

  memberships UserOrganization[]
  scopedBy    UserRoleScope[]

  @@index([kind])
  @@index([isVirtual])
}

// ─────────────────────────────────────────────────────────
// 用户
// ─────────────────────────────────────────────────────────
// @module: user
model User {
  id           String   @id @default(cuid())
  username     String   @unique // 员工编号 / 登录名
  name         String // 显示名
  email        String?  @unique
  phone        String?
  avatarUrl    String?
  active       Boolean  @default(true)
  externalId   String?  @unique // Casdoor 等外部 IdP 的 sub
  // 自定义字段值 (基于 UserCustomField 定义)
  // JSON 字符串,结构: { [fieldCode]: stringValue, ... }
  // 例: '{"hire_date":"2020-03-15","education":"bachelor","id_card_no":"110..."}'
  // 字段缺失=未填,空字符串=已清空
  customFields String?
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  memberships  UserOrganization[]
  roles        UserRole[]
  certificates Certificate[] // V2:作为持证人的已发证书
}

// 用户 ↔ 组织 多对多 (一人可挂多个组织,但只能有一个 primary)
// @module: user
model UserOrganization {
  userId    String
  orgId     String
  user      User         @relation(fields: [userId], references: [id], onDelete: Cascade)
  org       Organization @relation(fields: [orgId], references: [id], onDelete: Cascade)
  isPrimary Boolean      @default(false)
  position  String? // 兼任职务,如 "支部书记"
  sortOrder Int          @default(0) // 成员在本机构内的排序(拖拽排序;仅对直接成员有意义)
  joinedAt  DateTime     @default(now())

  @@id([userId, orgId])
  @@index([orgId])
}

// ─────────────────────────────────────────────────────────
// 角色 / 权限 (RBAC + 数据范围)
// ─────────────────────────────────────────────────────────
// @module: role
model Role {
  id          String   @id @default(cuid())
  code        String   @unique // party_secretary | admin | member ...
  name        String // 显示名,如 "党委书记"
  description String?
  builtin     Boolean  @default(false) // 内置角色不允许删除
  createdAt   DateTime @default(now())

  users       UserRole[]
  permissions RolePermission[]
}

// 用户 ↔ 角色,并附带数据范围 (4 级权限模型中的"数据权限")
// scope 取值 (通用化,与组织 kind 解耦,行政/党组织均适用):
//   self     仅本人
//   own      仅本组织直接成员 (不含子组织)
//   subtree  本组织 + 所有下级
//   all      全平台
//   custom   自定义子树集合,具体范围由 scopeOrgs 关联表的多条记录定义 (允许多个子树并集)
//
// 字段调整说明:
//   原 scopeOrgId 单值字段已删除,改为通过 UserRoleScope 关联表表达"一个用户在某角色下可见的多棵子树"。
//   primary key 从 [userId, roleId] 复合主键改为自增 id,以便 UserRoleScope 通过外键引用。
// @module: role
model UserRole {
  id        String          @id @default(cuid())
  userId    String
  roleId    String
  user      User            @relation(fields: [userId], references: [id], onDelete: Cascade)
  role      Role            @relation(fields: [roleId], references: [id], onDelete: Cascade)
  scope     String          @default("self")
  scopeOrgs UserRoleScope[]
  grantedAt DateTime        @default(now())

  @@unique([userId, roleId])
  @@index([roleId])
}

// 用户角色数据范围 (scope=custom 时使用)
// 一条 UserRole 可以关联 0..N 个组织,代表"该用户用此角色看哪些子树"。
// 例:某副总在 'dept_manager' 角色下 scope=custom,scopeOrgs 同时指向 IT 中心 + 业务发展部,
//      表示他能管理这两个部门的人员/数据。
//
// scope ∈ {self, own, subtree, all} 时 scopeOrgs 应为空。
// @module: role
model UserRoleScope {
  userRoleId String
  orgId      String
  userRole   UserRole     @relation(fields: [userRoleId], references: [id], onDelete: Cascade)
  org        Organization @relation(fields: [orgId], references: [id], onDelete: Cascade)
  createdAt  DateTime     @default(now())

  @@id([userRoleId, orgId])
  @@index([orgId])
}

// 权限点
// category 取值:
//   menu       菜单可见
//   operation  操作 (按钮/接口)
//   field      字段访问
//   data       数据权限 (作为标记,实际范围由 UserRole.scope 控制)
// @module: permission
model Permission {
  id          String   @id @default(cuid())
  code        String   @unique // certificate:issue / user:read ...
  name        String
  description String?
  category    String // menu | operation | field | data
  pluginName  String? // 来源插件 (null 表示平台自有)
  builtin     Boolean  @default(false)
  createdAt   DateTime @default(now())

  roles RolePermission[]
}

// @module: role (junction; permission 模块只读)
model RolePermission {
  roleId       String
  permissionId String
  role         Role       @relation(fields: [roleId], references: [id], onDelete: Cascade)
  permission   Permission @relation(fields: [permissionId], references: [id], onDelete: Cascade)

  @@id([roleId, permissionId])
}

// ─────────────────────────────────────────────────────────
// 数据字典 (统一管理下拉枚举值,避免硬编码 + 输入混乱)
// ─────────────────────────────────────────────────────────
// 典型使用场景:
//   admin_position    行政职务   (经理 / 主管 / 工程师 / 干事 ...)
//   party_position    党组织职务 (党员 / 支部书记 / 党委委员 ...)
//   user_education    学历      (大专 / 本科 / 硕士 ...)
//   ...
//
// 任何下拉框都可以引用 Dictionary.code 拉取 DictItem 列表填充。
// 后续用户自定义字段 (UserCustomFieldDef) 在 type='select' 时也通过 dictCode 关联到这里。
// @module: dictionary
model Dictionary {
  id          String   @id @default(cuid())
  code        String   @unique // 字典代码,如 'admin_position'
  name        String // 显示名,如 '行政职务'
  description String?
  builtin     Boolean  @default(false) // 内置字典 (核心业务依赖,不允许删除)
  sortOrder   Int      @default(0)
  active      Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  items DictItem[]

  @@index([active])
}

// 字典项 — 支持 2 级分类
//   parentId=null  根级项,作为"分类"使用 (如 管理类 / 技术类 / 操作类)
//   parentId≠null  二级项,可被业务字段实际选用 (如 经理 / 工程师 / 专员)
// 强制 2 级:parent 必须自身是根级 (parentId=null)
// 兼容:parentId 留空可作 1 级扁平字典使用 (如 学历 / 政治面貌)
// @module: dictionary
model DictItem {
  id          String     @id @default(cuid())
  dictId      String
  dict        Dictionary @relation(fields: [dictId], references: [id], onDelete: Cascade)
  parentId    String?
  parent      DictItem?  @relation("DictItemTree", fields: [parentId], references: [id], onDelete: Cascade)
  children    DictItem[] @relation("DictItemTree")
  code        String // 项代码 (组内唯一)
  label       String // 显示文字
  description String?
  sortOrder   Int        @default(0)
  active      Boolean    @default(true)
  createdAt   DateTime   @default(now())
  updatedAt   DateTime   @updatedAt

  @@unique([dictId, code])
  @@index([dictId])
  @@index([parentId])
}

// ─────────────────────────────────────────────────────────
// 用户自定义字段 (元数据驱动表单)
// ─────────────────────────────────────────────────────────
// 由管理员在 /admin/system/custom-fields 维护,User.customFields 实际值依此校验和渲染。
//
// type 取值:
//   text       单行文本
//   number     数字 (前端 type=number,后端仍存 string)
//   date       日期 (YYYY-MM-DD 字符串)
//   textarea   多行文本
//   select     从 dictCode 指定的字典中选择,存字典项 code (而非 label,允许字典 label 变更)
//
// 添加新字段对已有用户无破坏:user.customFields[新code] 暂为空即可,加载/保存均忽略缺失字段。
// 字段被删除或禁用:对应用户值保留在 customFields 里但不再展示。
// @module: user-custom-field
model UserCustomField {
  id          String   @id @default(cuid())
  code        String   @unique // hire_date / education / id_card_no
  label       String // 入职日期 / 学历 / 身份证号
  type        String // text | number | date | textarea | select
  dictCode    String? // type=select 时引用 Dictionary.code
  placeholder String?
  description String? // 输入框下方帮助文字
  required    Boolean  @default(false)
  sortOrder   Int      @default(0)
  active      Boolean  @default(true)
  builtin     Boolean  @default(false) // 内置字段不允许删除
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@index([active, sortOrder])
}

// ─────────────────────────────────────────────────────────
// 首页导航 (6 大分类 + 项目两级结构)
// ─────────────────────────────────────────────────────────
// NavPage 的 "全部导航" 区域由这两张表驱动。
//
// icon 字段存 lucide-react 图标的 PascalCase 名称(如 "BookOpenIcon"),
// 前端运行时通过 `(lucide as any)[item.icon]` 解析为组件。
//
// color 字段存 hex/rgb 字符串,作为该分类/项目的视觉主色。这是"分类色",
// 与主题色解耦 —— 不同分类用不同颜色区分(党务红、学习橙、统计蓝...)。
// @module: nav-category
model NavCategory {
  id        String   @id @default(cuid())
  code      String   @unique // 程序内标识,如 'party-affairs'
  label     String // 显示名,如 '党务办理'
  color     String // 分类主色 hex,如 '#C8001E'
  bgLight   String // 配套淡色背景 hex,如 '#FFF5F5'
  icon      String // lucide 图标名,如 'ClipboardListIcon'
  sortOrder Int      @default(0)
  active    Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  items NavItem[]

  @@index([active, sortOrder])
}

// @module: nav-category
model NavItem {
  id         String      @id @default(cuid())
  categoryId String
  category   NavCategory @relation(fields: [categoryId], references: [id], onDelete: Cascade)
  icon       String // lucide 图标名
  label      String // 显示名,如 '党费缴纳'
  color      String // 项目色 hex
  url        String? // 点击跳转 URL(站内 /plugins/... 或外链)
  common     Boolean     @default(false) // 是否常用(打 "常用" 标 + 出现在快捷条)
  desc       String? // 一行描述
  likes      Int         @default(0) // 点赞数(后续接真实统计)
  views      Int         @default(0) // 浏览数
  sortOrder  Int         @default(0)
  active     Boolean     @default(true)
  createdAt  DateTime    @default(now())
  updatedAt  DateTime    @updatedAt

  @@index([categoryId, sortOrder])
  @@index([active])
}

// ─────────────────────────────────────────────────────────
// 站点设置 (品牌/首页文案/页脚/主题色 等)
// ─────────────────────────────────────────────────────────
// 单例表:全表只有一行,id 固定为 "default"。
// data 字段存 JSON 字符串,前后端共享 TypeScript 类型 SiteSettingsData。
//
// 选择 JSON 而非每个字段一列的理由:
//   1. 字段以后会持续增加 (页脚链接、导航菜单、配色、字号缩放等),用 JSON 加字段不需要 migrate
//   2. 前后端契约由 TS 类型管,而不是数据库 schema
//   3. 单例表只有 GET / PUT,无需复杂查询和索引
//
// 前台 (NavPage) 通过公开接口 GET /site-settings 获取;后台 (管理员) 通过 PUT /site-settings 更新。
// @module: site-setting
model SiteSetting {
  id        String   @id // 固定 "default"
  data      String // JSON 字符串
  updatedAt DateTime @updatedAt
}

// ─────────────────────────────────────────────────────────
// 审计日志
// ─────────────────────────────────────────────────────────
// 平台关键写操作 (角色/组织/权限变更) 与敏感读操作通过 AuditService.log()
// 落入此表。前端 /admin/audit 页面只读浏览。
//
// action 命名约定:domain.verb
//   org.create / org.update / org.move / org.delete
//   user.create / user.update / user.deactivate
//   role.grant / role.revoke / role.update
//   plugin.install / plugin.enable / plugin.disable
//   auth.login / auth.logout
//
// detail 存 JSON 串,记录改动前后差异或额外上下文。
// @module: audit
model AuditLog {
  id         String   @id @default(cuid())
  actorId    String? // 操作者 user id
  actorName  String? // 冗余姓名,actor 被删后仍可读
  action     String // 见上方命名约定
  target     String? // 目标资源 ID
  pluginName String? // 来源插件 (null = 平台自有)
  detail     String? // JSON 串
  ip         String? // 操作来源 IP
  createdAt  DateTime @default(now())

  @@index([createdAt])
  @@index([actorId])
  @@index([action])
  @@index([pluginName])
}

// ─────────────────────────────────────────────────────────
// 外部 API 接入(LLM / 短信 / 邮件 / 对象存储 / ...)
// ─────────────────────────────────────────────────────────
// 管理员在「系统设置 → 外部 API」录入 apiKey/apiUrl/model,
// 应用层(如 extraction.service)通过 ExternalApiService.getKeyForProvider(code)
// 读取:DB 优先 → .env 兜底 → null。
//
// provider 命名约定:小写英文/数字/横线,如:
//   deepseek / openai / qwen / doubao / ernie / claude
//   sms-aliyun / sms-tencent / email-smtp / oss-aliyun
//
// apiKey 在 DB 明文存(单机 dev 阶段 OK,生产建议加 AES-GCM 加密 + KMS)。
// API 响应里始终脱敏 (前 4 + 后 4,中间 ***)。
// @module: external-api
model ExternalApi {
  id           String   @id @default(cuid())
  provider     String   @unique // 平台标识,如 'deepseek'
  name         String // 显示名,如 'DeepSeek 大模型'
  description  String?
  // 'cloud' = 云平台(需 apiKey);'internal' = 内网自建(OpenAI 兼容,可无 key)
  kind         String   @default("cloud")
  // 图标引用(中央图标库):lucide:X / brand:X / asset:<id>;空 = 按 provider 名自动品牌头像
  iconRef      String?
  apiKey       String? // 明文密钥(internal 内网直连时可空)
  apiUrl       String? // 自定义 endpoint(internal 必填内网地址,如 http://10.x:8000/v1)
  model        String? // 默认文本模型
  visionModel  String? // 多模态/视觉模型(OCR 用)。空 = 走 model 兜底
  imageModel   String? // 图像生成/图生图模型(SeedEdit 等,出图)。空 = 不支持生图,不与文本/视觉模型混用
  model3d      String? // 3D 生成模型(Seed3D 等,异步出 .glb 3D 模型)。空 = 不支持 3D 生成
  ttsModel     String? // 语音合成(TTS)模型。空 = 不支持配音
  ttsVoice     String? // TTS 音色标识(provider 各自的音色名,如火山的 voice_type)。空 = 用 provider 默认
  ttsControlInstruction String? // TTS 播报风格控制指令(VoxCPM control_instruction / 云 OpenAI-tts instructions / IndexTTS2 情感描述);空 = 用内置默认
  rechargeUrl  String? // 平台充值/计费控制台 URL
  priority     Int      @default(50) // 业务优先级,大者优先。getActive*() 按此降序选
  capabilities String   @default("chat") // 能力标签逗号分隔:chat/vision/reasoning
  webSearch    Boolean  @default(false) // 该模型支持联网搜索(千问 enable_search);知识库 AI 归档「一键联网检索」据此显隐
  active       Boolean  @default(true)
  meta         String? // JSON 扩展(超时/温度等)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  @@index([active])
  @@index([priority])
}

// 「按应用路由」绑定:每个 AI 消费功能(ai-consumers.ts 的 consumerKey)→ 指定 provider。
// 不存在对应行 = 自动(按该功能所需能力,取优先级最高的 active provider)。
// provider 松引用 ExternalApi.provider(同模块,但故意不建 relation:绑定的 provider
// 被删/禁用时优雅回退到自动,而非外键报错)。
// @module: external-api
model AiRoute {
  id          String   @id @default(cuid())
  consumerKey String   @unique // 对应 AI_CONSUMERS[].key,如 'certificate.extract.text'
  provider    String? // 绑定到的 ExternalApi.provider;null/缺行 = 自动按优先级
  updatedById String? // 最后修改人(审计冗余)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

// AI 提示词覆盖表 —— 后台改过的提示词存这里(key→content);默认值在代码 prompt/ai-prompts.ts。
// 无行 = 用代码默认值;删行 = 还原默认。
// @module: prompt
model AiPrompt {
  key         String   @id // = AI_PROMPTS[].key,如 'avatar.generate'
  content     String // 覆盖后的提示词全文
  updatedById String? // 最后修改人(审计冗余)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

// 中央图标库 —— 自定义上传的图标。内联存 dataUrl(图标小、公开页 <img> 直接用、零鉴权)。
// 内置品牌图标(deepseek/豆包…)是前端 monogram 注册表,不进此表。
// @module: icon
model IconAsset {
  id          String   @id @default(cuid())
  name        String
  mimeType    String
  ext         String
  size        Int
  dataUrl     String // data:<mime>;base64,xxxx
  createdById String?
  createdAt   DateTime @default(now())
}

// ─────────────────────────────────────────────────────────
// 证书管理(V1:模板;V2:模板 + 发证 + 公开验证 + AI 提取)
// ─────────────────────────────────────────────────────────
// 一个 CertificateTemplate 就是「证书的可视化设计 + 变量字段定义」,
// designJson 序列化整个 DesignerState(elements 数组 + background +
// canvas 尺寸 + 变量字段),由前端 Canvas 设计器读写。
//
// V2:Certificate 表挂接发证记录,onDelete:Restrict 保护已发模板不被误删。
// honorCode 是 V2 加的:荣誉首字母代码(如 "QDJL" 庆典奖励),
// 用于证书编号生成 {年份}-{honorCode}-{batchTotal}-{batchSeq}。
// 一个模板 = 一种荣誉。
// @module: certificate
model CertificateTemplate {
  id          String   @id @default(cuid())
  name        String // 模板名,如"年度优秀党员证书"
  description String?
  category    String? // 分类:奖励/荣誉/培训... 留 null 即可
  honorCode   String? // V2:荣誉代码(字母数字,如 "QDJL")。发证时拷贝快照到 Certificate
  // V3 新增:模板自带荣誉元数据,发证时一并落到 Certificate
  honorType   String? // individual | collective(发证页类型不再让用户选,由模板带出)
  honorLevel  String? // 字典 cert_honor_level 的 code(默认 company/department/subsidiary)
  // V3+:落款单位(发证机构),证书印章顶部弧形文字默认引用此值
  issuingOrgName String?
  designJson  String // DesignerState 序列化(JSON 字符串)
  thumbnail   String? // 缩略图(data URL / base64),列表显示用
  width       Int      @default(800) // 画布宽 px
  height      Int      @default(566) // 画布高 px
  active      Boolean  @default(true) // 禁用不删
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  createdBy   String? // user id,可空

  certificates Certificate[] // V2 反向关联

  @@index([active])
  @@index([category])
}

// 已发证书 — V2 新增
// 编号 certNo 格式:{yearLabel}-{honorCode}-{batchTotal}-{batchSeq3位}
//   例:2024-QDJL-100-001
// batchKey = `${yearLabel}-${honorCode}-${batchTotal}`,同批次共享 → batchSeq 在批内 1..batchTotal
// 追加发证视为新批次(batchTotal 不同)
//
// source 取值:
//   internal  用本系统模板生成,有 templateId
//   external  上传的外部 PDF,templateId=null,pdfFileId 指向上传的原件
//
// V4(storage):证书 PDF 大文件不再 base64 进库,改存 storage 模块,Certificate 只留
// pdfFileId 指针;缩略图 thumbnail 仍存 DB(小)。批量下载 / 公开下载经 StorageService 取字节。
// @module: certificate
model Certificate {
  id          String  @id @default(cuid())
  certNo      String  @unique // 完整证书编号,如 "2024-QDJL-100-001"
  yearLabel   String // 年份段,如 "2024" 或 "2024-2025"
  honorCode   String // 荣誉首字母快照
  batchKey    String // `${yearLabel}-${honorCode}-${batchTotal}` 同批次共享
  batchTotal  Int // 本批次总数
  batchSeq    Int // 批内序号,1-based
  publicToken String  @unique // 公开验证 URL token

  templateId String?
  template   CertificateTemplate? @relation(fields: [templateId], references: [id], onDelete: Restrict)

  // 持证人来源 + 关联 + 快照
  source          String  @default("internal") // internal | external
  // 荣誉类型(V3):individual | collective | unit
  //   individual:个人荣誉,recipientName=人名,可关联 User
  //   collective:集体荣誉,recipientName=集体名,自由文本
  //   unit:单位荣誉(如"先进基层党组织"),recipientName=单位名,自由文本
  // 老数据 null 兼容,前端按 individual 渲染
  honorType       String?
  recipientUserId String?
  recipientUser   User?   @relation(fields: [recipientUserId], references: [id], onDelete: SetNull)
  recipientName   String // 持证人姓名(必填,即使关联 User 也存快照)
  recipientEmpNo  String? // 员工编号快照(= User.username)
  recipientDept   String? // 部门快照
  recipientIdCard String? // 身份证号(可选)
  recipientPhone  String?

  // 变量值快照 — 发证时把表单值固化进来。即使后续改模板变量定义,本张还能还原
  variableData String // JSON 字符串,形如 { name: "张三", certNo: "...", ... }

  // 时间
  issueDate  DateTime  @default(now())
  validUntil DateTime? // 永久 = null

  // 发证人 + 机构(快照,审计需要)
  issuedBy       String // user id
  issuerName     String // 发证人姓名
  issuingOrgId   String? // Organization id(发证机构)
  issuingOrgName String?

  // 撤销
  revoked       Boolean   @default(false)
  revokedAt     DateTime?
  revokedReason String?
  revokedBy     String?

  // 渲染产物 / 文件指针(V4 storage:大文件移出 DB,只存 fileId → StoredFile)
  pdfFileId        String? // 证书 PDF:internal=生成件 / external=上传原件 → StoredFile.id
  sourceFileId     String? // 该表彰的原始表彰文件(best-effort 存)→ StoredFile.id;供日后查看原文
  // 压缩预览缩略图(发证时前端从同一次渲染降采样生成的 JPEG base64,约几十 KB)继续存 DB —
  // 列表卡片 + 公开页 <img> 直接用,小且不受 data:PDF 非 HTTPS 渲染限制。external 为 null。
  thumbnail        String? // JPEG data URL(压缩预览图)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([templateId])
  @@index([recipientUserId])
  @@index([revoked])
  @@index([issueDate])
  @@index([batchKey])
  @@index([source])
  @@index([certNo])
}

// 统一文件存储 — 平台基础设施模块。一行 = 一个已落地文件的「元数据」,
// 真实字节由 StorageDriver 存到后端(本地盘 / 挂载的群晖共享盘);本表只存指针 + 校验信息。
// 消费方(certificate / task 等)用 fileId 松引用本表(string),不建 relation —— 守住「表归属单一模块 + 依赖图 DAG」。
// sqlite/postgres 兼容:仅用 String/Int/DateTime/Boolean。
// @module: storage
model StoredFile {
  id           String    @id @default(cuid())
  driver       String // 'local'(未来 'synology' | 's3')—— 存「写入时」的 driver,多后端共存/迁移时按行回查
  storageKey   String    @unique // driver 内相对路径,如 'certificate/2025-先进工作者/先进工作者-张三-1001.pdf'
  ownerModule  String // 'certificate' | 'task' … 业务来源(= 顶层文件夹 + 孤儿排查)
  folder       String? // 业务子文件夹(冗余存,便于按文件夹查/审计)
  originalName String // 原始/展示文件名(下载时拼 Content-Disposition)
  mimeType     String
  size         Int // 字节数(够用;真要存超大文件再换 BigInt)
  sha256       String // 内容哈希(hex)—— 完整性校验 / 排查重复
  ext          String? // 规范化小写扩展名(无点),如 'pdf'
  visibility   String    @default("private") // 'private' | 'public'
  createdById  String? // 上传者 user id
  createdAt    DateTime  @default(now())
  deletedAt    DateTime? // 软删:置戳后下载拒绝,真实字节由孤儿回收延迟清

  @@index([ownerModule])
  @@index([folder])
  @@index([sha256])
  @@index([deletedAt])
}

// ─────────────────────────────────────────────────────────
// 任务分派(下发 → 填报 → 汇总)
// ─────────────────────────────────────────────────────────
// 通用「下发-填报-汇总」底座:部门建模板(可复用表单 schema)→ 派发成一次 Task(fan-out 到多个
// 单位/个人 TaskTarget)→ 接收方责任人(单人)+ 协同填报人(多人)共填一份 TaskSubmission →
// 派发人汇总。接收单位用 UnitTaskRouting 配「上级部门 → 本单位责任人」实现任务自动划转。
//
// 跨模块一律 fileId / userId / orgId 松引用(普通 string,不建 relation),守「表归属单一模块 + DAG」
// (同 storage 决策)。文件/图片字段的值存 storage 的 fileId;富文本存 HTML/JSON;在线文档存引用。
// sqlite/postgres 兼容:仅用 String/Int/DateTime/Boolean。

// 任务模板 — 可复用的表单 schema(通用性核心)。如「报送党员数据」。
// fields 存 JSON:TaskField[](字段定义,支持分组 group/groupLabel + 多类型 + 约束),
// 结构与 UserCustomField 一脉相承(见 src/task/dto)。
// @module: task
model TaskTemplate {
  id          String   @id @default(cuid())
  code        String   @unique
  name        String
  description String?
  category    String? // 数据报送 / 材料报送 / 通知回执 …
  fields      String // JSON: TaskField[]
  builtin     Boolean  @default(false)
  active      Boolean  @default(true)
  createdById String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@index([active])
  @@index([category])
}

// 任务 — 一次具体派发,汇总根。fields 是派发时对模板的快照(模板后续改动不影响已派任务)。
// dispatchOrgId = 派发部门,接收方「对口路由」按此匹配 UnitTaskRouting.sourceOrgId。
// @module: task
model Task {
  id             String    @id @default(cuid())
  title          String
  description    String? // 重点描述 / 填报口径
  notes          String? // 注意事项(AI 可从通知文件抽取,单独高亮给填报人)
  templateId     String? // 来源模板(可空 = 临时任务)
  fields         String // JSON 快照:TaskField[]
  dispatchUserId String // 派发人 user id
  dispatchOrgId  String? // 派发部门 org id(对口路由匹配键)
  dueAt          DateTime? // 截止时间(可空 = 不限)
  noticeFileId   String? // 通知文件(storage fileId,可空)
  noticeFileName String? // 通知文件原始名(展示用)
  status         String    @default("open") // draft | open | closed | archived
  // 周期报表:同一报表的各期用 seriesId 串联(= 首期任务 id);periodLabel 如「2026年6月」。
  // 一次性任务 seriesId/periodLabel 为空。每期仍是独立 Task(锁定/审核/汇总全复用)。
  seriesId       String? // 系列 id(= 首期任务 id);null = 非周期任务
  periodLabel    String? // 期次标签(如「2026年6月」)
  createdAt      DateTime  @default(now())
  updatedAt      DateTime  @updatedAt

  @@index([dispatchUserId])
  @@index([dispatchOrgId])
  @@index([status])
  @@index([seriesId])
}

// 派发对象 — fan-out:任务派给哪些单位/个人。一个 Task 多个 TaskTarget。
// targetType=org:派给单位,命中对口则记责任部门 handlerOrgId(待该部门认领);targetType=user:直派个人,该人即责任人。
// ownerUserId = 责任人(唯一,认领后才有)。handlerOrgId = 对口责任部门(认领前的可见域)。status 是该对象维度的进度。
// @module: task
model TaskTarget {
  id           String    @id @default(cuid())
  taskId       String
  targetType   String // 'org' | 'user'
  targetOrgId  String? // targetType=org
  targetUserId String? // targetType=user(直派个人,即责任人)
  ownerUserId  String? // 责任人(唯一):接收认领 / 管理员分派 / 直派个人(认领前为空)
  handlerOrgId String? // 对口责任部门(命中对口路由时写;认领前供该部门成员可见待办)
  status       String    @default("pending") // pending | assigned | in_progress | submitted | returned | done
  assignedById String? // 由谁分派(系统对口命中 = null;手动 = 接受管理员 id)
  assignedAt   DateTime?
  // 平级确认(P2):跨机关部门互派(机关↔机关)需「双方部门负责人」确认后才生效。
  // confirmStatus: none(无需确认,默认直生效) | pending(待双方确认) | approved(双方通过,激活) | rejected(被驳回,作废)
  // senderConfirm/receiverConfirm: null=未决 | approved | rejected。派发人本人即发方负责人(或发方部门未设负责人)→ 发方派发时自动通过。
  confirmStatus       String    @default("none")
  senderConfirm       String? // 发方(派发部门)负责人决定
  senderConfirmById   String?
  receiverConfirm     String? // 收方(目标部门)负责人决定
  receiverConfirmById String?
  confirmNote         String? // 驳回原因(任一方驳回时写)
  confirmActedAt      DateTime? // 最后一次确认/驳回时间
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt

  @@index([taskId])
  @@index([targetOrgId])
  @@index([targetUserId])
  @@index([ownerUserId])
  @@index([handlerOrgId])
  @@index([status])
  @@index([confirmStatus])
}

// 协同填报人 — 一个 target 可多人共填一份回执;责任人 = TaskTarget.ownerUserId(唯一),
// 此表存额外加入的填报人。
// @module: task
model TaskCollaborator {
  id        String   @id @default(cuid())
  targetId  String
  userId    String
  addedById String?
  addedAt   DateTime @default(now())

  @@unique([targetId, userId])
  @@index([userId])
}

// 填报回执 — 每个 target 一份(责任人唯一 → 一份,多人协同编辑同一份)。
// formData JSON:{ [fieldCode]: value };file/image → storage fileId,richtext → HTML/JSON,doclink → {provider,ref}。
// fileIds 冗余汇总该回执引用的所有 storage fileId,便于展示与孤儿回收。
// @module: task
model TaskSubmission {
  id            String    @id @default(cuid())
  taskId        String
  targetId      String    @unique
  formData      String    @default("{}") // JSON { [fieldCode]: value }
  fileIds       String? // JSON string[]
  status        String    @default("draft") // draft | submitted | returned | approved
  submittedById String?
  submittedAt   DateTime?
  reviewNote    String? // 退回意见
  reviewedById  String?
  reviewedAt    DateTime?
  returnCount   Int       @default(0) // 累计被退回次数(每退回一次 +1,画像考核用)
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  @@index([taskId])
}

// 对口配置 — 「部门对口」:某机关部门(sourceOrgId)派来的任务,在本单位(unitOrgId)默认由「责任部门」(handlerOrgId)承接。
// 该责任部门成员都能看到,直到有人「接收」认领为责任人(认领前 TaskTarget.ownerUserId 为空)。
// 派发时 task.service 查 (unitOrgId = 目标单位, sourceOrgId = Task.dispatchOrgId):命中即把责任部门写进 TaskTarget.handlerOrgId。
// @module: task
model UnitTaskRouting {
  id           String   @id @default(cuid())
  unitOrgId    String // 本单位(二级单位)org id
  sourceOrgId  String // 机关部门 org id(匹配 Task.dispatchOrgId)
  handlerOrgId String // 本单位对口「责任部门」org id(认领前该部门成员可见)
  createdById  String?
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  @@unique([unitOrgId, sourceOrgId])
  @@index([unitOrgId])
}

// ─────────────────────────────────────────────────────────
// 企业虚拟展厅(数据驱动:一个展厅 = 一份空间文档)
// ─────────────────────────────────────────────────────────
// @module: exhibition  虚拟展厅空间文档
// walls/fixtures/meta 均为 JSON 串(SQLite 无原生 JSON);素材一律松引用 storage fileId,
// 不建跨模块外键。GET /halls/:id 时由 service 把 fileId 解析成公开素材 URL(即「已解析」展厅)。
model Hall {
  id              String   @id @default(cuid())
  name            String
  thumbnailFileId String? // 封面图 storage fileId(松引用 StoredFile)
  metaJson        String   @default("{}") // { gridM, wallH, theme:{floorMat,wallMat,lighting} }
  envModelFileId  String? // 可选:Blender 烘焙的房间外壳 .glb 的 fileId(替换程序化墙)
  wallsJson       String   @default("[]") // Wall[]: {id,x1,y1,x2,y2}(米,原点在平面图中心)
  fixturesJson    String   @default("[]") // Fixture[]: 组件实例(source.mode = manual | connector)
  published       Boolean  @default(false)
  sortOrder       Int      @default(0)
  createdById     String? // 创建人 user id(松引用)
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  @@index([published])
}

// @module: exhibition  模型库条目元数据(分类标签;展示名直接改 StoredFile.originalName)
// fileId 松引用 StoredFile —— 模型删除后残留行无害(列表 join 不到即忽略)
model ModelLibraryMeta {
  fileId    String   @id
  tags      String   @default("[]") // JSON string[],如 ["设备","党建"]
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

// @module: exhibition  讲解员「形象包」—— 一套立绘/3D 形象 + 音色 + 肩点参数,可复用到任意厅
// configJson = HallGuide 配置子集(kind/sprite*FileId/voice/voiceRef/armPivot 等);fileId 松引用 StoredFile
model ExhibitionGuidePreset {
  id          String   @id @default(cuid())
  name        String
  configJson  String   @default("{}")
  createdById String? // 创建人 user id(松引用)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

// ─────────────────────────────────────────────────────────
// 实体会议室 — 物理空间。一个会议室可挂多张会场图。
// @module: venue
model MeetingRoom {
  id           String        @id @default(cuid())
  name         String
  location     String? // 楼栋/楼层/房间号等
  capacity     Int           @default(0) // 标称容量(人)
  description  String?
  photoFileIds String? // JSON string[]:现场照片 storage fileId(松引用 StoredFile)
  facilities   String? // JSON string[]:硬件设施标签(视频会议/音响/投屏/同声传译/录播…)
  orgId        String? // 归属单位 org id(松引用 Organization);null = 全局可用
  active       Boolean       @default(true)
  createdById  String?
  createdAt    DateTime      @default(now())
  updatedAt    DateTime      @updatedAt
  layouts      VenueLayout[]

  @@index([active])
  @@index([orgId])
}

// 会场图 — 一张布置方案的画布。layoutJson 是可 JSON.parse 还原的 VenueDesignerState
// (elements 含 seat/zone 稳定 id + 网格设置 + 背景)。thumbnail 列表展示用;seatCount 缓存座位数。
// @module: venue
model VenueLayout {
  id          String        @id @default(cuid())
  roomId      String
  room        MeetingRoom   @relation(fields: [roomId], references: [id], onDelete: Cascade)
  name        String
  layoutJson  String // JSON: VenueDesignerState
  thumbnail   String? // data URL 缩略图
  width       Int           @default(1200)
  height      Int           @default(800)
  gridSize    Int           @default(20)
  seatCount   Int           @default(0) // 保存时回填,列表/选座展示用
  active      Boolean       @default(true)
  status      String        @default("published") // draft 草稿 | published 已发布
  createdById String?
  createdAt   DateTime      @default(now())
  updatedAt   DateTime      @updatedAt
  plans       SeatingPlan[]

  @@index([roomId])
  @@index([active])
}

// 选座方案 — 一次活动,绑定一张会场图。
// @module: venue
model SeatingPlan {
  id                 String              @id @default(cuid())
  layoutId           String
  layout             VenueLayout         @relation(fields: [layoutId], references: [id], onDelete: Restrict)
  name               String
  eventDate          DateTime?
  rosterJson         String              @default("[]") // JSON Attendee[]
  rulesJson          String              @default("[]") // JSON SeatingRule[]
  status             String              @default("draft") // draft | computed | finalized
  layoutSnapshotJson String? // 计算/定稿时的会场图快照(防 layout 后续改动错位)
  createdById        String?
  createdAt          DateTime            @default(now())
  updatedAt          DateTime            @updatedAt
  assignments        SeatingAssignment[]

  @@index([layoutId])
  @@index([status])
}

// 座位分配 — 一行 = 一个被分到具体座位的与会人。seatId 引用 layoutJson 里 seat 元素的稳定 id。
// attendeeId 为空 = 空座/预留。source 区分来源(自动评分填 / 规则锁定 / 手动拖动)。
// @module: venue
model SeatingAssignment {
  id           String      @id @default(cuid())
  planId       String
  plan         SeatingPlan @relation(fields: [planId], references: [id], onDelete: Cascade)
  seatId       String
  attendeeId   String? // null = 空座/预留
  attendeeName String?
  unit         String?
  position     String?
  score        Float?
  source       String      @default("auto") // auto | rule | manual | locked
  createdAt    DateTime    @default(now())
  updatedAt    DateTime    @updatedAt

  @@unique([planId, seatId])
  @@index([planId])
  @@index([unit])
  @@index([position])
  @@index([attendeeId])
}

// ─────────────────────────────────────────────────────────
// 党组织 ↔ 行政机构 关联 (N:M;党委/党总支当前 1:1;手动维护)
// 考核(assessment)等模块据此把党组织对象解析到行政机构去取业务数据。
// 松引用:两端都是 Organization,只存 id 不建 @relation。
// ─────────────────────────────────────────────────────────
// @module: organization
model PartyAdminLink {
  id          String   @id @default(cuid())
  partyOrgId  String // 党组织 org id (kind=party)
  adminOrgId  String // 行政机构 org id (kind=admin)
  note        String?
  createdById String?
  createdAt   DateTime @default(now())

  @@unique([partyOrgId, adminOrgId])
  @@index([partyOrgId])
  @@index([adminOrgId])
}

// ─────────────────────────────────────────────────────────
// 考核系统 (assessment) — 通用考核平台
// P1:考核体系(可复用模板)= 锁定指标树 + 定级规则 + 设置。
// 指标树存 JSON 快照 (IndicatorNode[],见 backend/src/assessment/indicator-tree.ts),不拆表。
// Round/Target/IndicatorScore/Goal 等打分相关表留待 P2。
// ─────────────────────────────────────────────────────────
// @module: assessment
// 一张「考核表」= 考核年度 + 考核内容(指标树)+ 考核对象(快照)。不做模板,复用=整体复制改年度。
model AssessmentScheme {
  id             String   @id @default(cuid())
  name           String // 「2026年度党建责任制考核(单位)」
  year           Int
  track          String   @default("party") // party(党建,对象=党组织) | admin(行政/业绩,对象=行政机构/员工)
  targetLevel    String   @default("committee") // 党建:committee(党委,1:1二级单位)/branch/member;行政:unit/dept/employee
  indicatorsJson String   @default("[]") // 3 级指标树快照 IndicatorNode[]
  // 考核对象快照 [{orgId,name}] —— 一次性从组织树读出后冻结,与组织机构解耦(单位每年会调整/合并)
  targetsJson    String   @default("[]")
  gradeRulesJson String   @default("{}") // {thresholds:[{grade,min}], vetoGrade}
  settingsJson   String   @default("{}") // {baseFullScore:100, bonusCap, deductionCap, vetoZero}
  status         String   @default("draft") // draft | active | archived
  createdById    String?
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  @@index([year])
  @@index([status])
  @@index([targetLevel])
}

// @module: assessment
// 考核轮次 = 一次实际发起的考核。创建时把考核表(指标树/对象/设置/定级规则)快照进来,与日后改表解耦。
// computeRound 产出写 resultsJson(各对象 得分/合计/排名/定级)。
model AssessmentRound {
  id             String   @id @default(cuid())
  schemeId       String
  name           String
  year           Int
  track          String   @default("party")
  indicatorsJson String   @default("[]") // 快照:指标树
  targetsJson    String   @default("[]") // 快照:考核对象 [{orgId|userId,name}]
  settingsJson   String   @default("{}") // 快照:baseFullScore/headcounts/difficultyTables…
  gradeRulesJson String   @default("{}") // 快照:定级规则
  resultsJson    String   @default("{}") // computeRound 产出:{computedAt, targets:[{ref,name,total,rank,grade,leafScores}]}
  status         String   @default("open") // open(填报中) | done(已计算)
  createdById    String?
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  scores    IndicatorScore[]
  confirms  AssessmentScoreConfirm[]
  snapshots AssessmentResultSnapshot[]

  @@index([schemeId])
  @@index([year])
  @@index([status])
}

// @module: assessment
// 分数确认会签:某轮次的某叶子指标的某责任人,确认「我已完成该指标打分、当前分数无误」。
// 总管理员(考核表创建者/协同维护人)发起 → 每个「有责任人的叶子 × 每个责任人」生成 pending → 责任人确认 → confirmed。
// 管理员据此看「哪个指标、谁还没确认」(带电话便于催)。note 预留(基层单位结果申诉是另一套体系,先记录)。
model AssessmentScoreConfirm {
  id          String          @id @default(cuid())
  roundId     String
  round       AssessmentRound @relation(fields: [roundId], references: [id], onDelete: Cascade)
  leafCode    String // 叶子指标 code(轮次快照里的)
  userId      String // 责任人 id(松引用 user)
  status      String          @default("pending") // pending | confirmed
  note        String? // 备注 / 申诉(预留)
  confirmedAt DateTime?
  createdAt   DateTime        @default(now())
  updatedAt   DateTime        @updatedAt

  @@unique([roundId, leafCode, userId])
  @@index([roundId])
  @@index([userId])
  @@index([status])
}

// @module: assessment
// 指标得分:轮次 × 考核对象 × 叶子指标。rawValue=原始度量(JSON 串,number/bool/label);score=计算后(computeRound 回填,可选)。
model IndicatorScore {
  id              String          @id @default(cuid())
  roundId         String
  round           AssessmentRound @relation(fields: [roundId], references: [id], onDelete: Cascade)
  targetRef       String // orgId 或 userId
  leafCode        String
  rawValue        String? // 原始度量 JSON(number/bool/"label");缺省=未填
  note            String?
  evidenceFileIds String? // JSON 数组(self_report 佐证 fileId,P3)
  createdAt       DateTime        @default(now())
  updatedAt       DateTime        @updatedAt

  @@unique([roundId, targetRef, leafCode])
  @@index([roundId])
}

// @module: assessment
// 考核结果快照:一轮制下「不重开轮」,到季度/截止日由管理员「手动生成并命名」一个只读结果定格
// (如「1季度结果」「上半年结果」)。打分继续在同一轮累积;快照 = 生成那一刻 computeRound 产出的
// 冻结副本(resultsJson 同 RoundResults 形状),供历次对比 / 留档。
model AssessmentResultSnapshot {
  id          String          @id @default(cuid())
  roundId     String
  round       AssessmentRound @relation(fields: [roundId], references: [id], onDelete: Cascade)
  label       String // 用户命名:「1季度结果」「上半年结果」
  resultsJson String          @default("{}") // 生成时刻 computeRoundResults 产出快照({computedAt, targets:[…]})
  note        String? // 备注(可选)
  createdById String?
  createdAt   DateTime        @default(now())

  @@index([roundId])
}

// ─────────────────────────────────────────────────────────
// 通用报送平台(report)— 「一次发布 · 多次提交」底座
// 与 task 的本质区别:提交无 @unique(一对象可多次提交)+ 提交=发票头+明细子行(master-detail)。
// 扶贫采买 = 它的一份配置(ReportTemplate code='fupin_purchase' + 导入清单),非专用 CRUD。
// 跨模块 fileId/orgId/userId 全松引用(普通 string,不建 relation);report 内部 relation+cascade。
// 详见 docs/specs/2026-06-16-report-platform.md
// ─────────────────────────────────────────────────────────

// @module: report
// 可复用表单 schema(扶贫采买 = 一条实例)。一年一配,轻量。fields=ReportField[] JSON 快照。
model ReportTemplate {
  id         String   @id @default(cuid())
  code       String   @unique // 'fupin_purchase'
  name       String
  fieldsJson String   @default("[]") // JSON: ReportField[](仿 task-fields 的 normalizeFieldDefs)
  catalogTag String? // 绑定哪批目录(扶贫='fupin-2026'),空=非目录型
  active     Boolean  @default(true)
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  @@index([active])
}

// @module: report
// 一次发布(= 任务根,仿 Task)。fields 是发布时对模板的快照(改模板不影响在途)。
model ReportTask {
  id             String    @id @default(cuid())
  templateId     String? // 松引用 ReportTemplate
  title          String
  notes          String? // 填报要求
  fieldsJson     String    @default("[]") // 发布时快照:ReportField[]
  goalsJson      String    @default("[]") // 目标定义快照:ReportGoal[](总额/分项/分部分/是否有内容,通用可多个)
  catalogTag     String? // 快照绑定的目录批次
  dispatchUserId String // 派发人 user id(松引用)
  dispatchOrgId  String? // 派发部门 org id(对口路由匹配键)
  dueAt          DateTime? // 截止时间(可空)
  noticeFileId   String? // 通知文件 storage fileId(可空)
  noticeFileName String? // 通知文件原始名(展示用)
  seriesId       String? // 周期报表串联各期(P3,= 首期任务 id)
  periodLabel    String? // 期次标签(如「2026」)
  status         String    @default("open") // draft | open | closed | archived
  createdAt      DateTime  @default(now())
  updatedAt      DateTime  @updatedAt

  @@index([dispatchUserId])
  @@index([dispatchOrgId])
  @@index([status])
  @@index([seriesId])
}

// @module: report
// fan-out 派发对象,仿 TaskTarget。★关键差异:提交无 @unique → 一对象多次提交。
// 不做平级确认(无机关互派);保留 handlerOrgId(对口责任部门)+ ownerUserId(认领/指派承办)。
model ReportTarget {
  id           String   @id @default(cuid())
  taskId       String
  targetType   String // 'org' | 'user'(扶贫主用 org)
  targetOrgId  String? // targetType=org
  targetUserId String? // targetType=user(直派个人)
  handlerOrgId String? // 对口责任部门(命中 ReportRouting 时写;认领前供该部门成员可见)
  ownerUserId  String? // 承办人(认领/指派,唯一)
  goalTargetsJson String @default("{}") // 逐单位目标值 { goalKey: 目标数值 }(targetMode=perUnit 的金额目标用;uniform 走 task.goals.target)
  status       String   @default("pending") // pending | in_progress | submitted | closed
  assignedById String? // 由谁指派(对口命中=null;手动指派=接收管理员 id)
  assignedAt   DateTime?
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  @@index([taskId])
  @@index([targetOrgId])
  @@index([targetUserId])
  @@index([handlerOrgId])
  @@index([ownerUserId])
  @@index([status])
}

// @module: report
// 对口路由:某单位的「报送责任部门」配置(仿 UnitTaskRouting,自有表守「表归属单一模块」)。
// 上级派发到单位 → 命中该单位配置的责任部门 handlerOrgId → 进该部门 inbox。
// scope='global' 或某 templateCode(可按报送类型分别配)。
model ReportRouting {
  id           String   @id @default(cuid())
  scope        String   @default("global") // 'global' | templateCode
  unitOrgId    String // 被派发的单位 org id
  handlerOrgId String // 该单位的报送责任部门 org id
  createdById  String?
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  @@unique([scope, unitOrgId])
  @@index([unitOrgId])
}

// @module: report
// ★一次提交 = 一张发票头。targetId 非 @unique(同对象多张发票=多条)。
// 发票/合同文件挂在头层(N 明细共享、不重复传);明细行不带文件指针。
model ReportSubmission {
  id             String    @id @default(cuid())
  taskId         String // 冗余,便于跨 target 聚合
  targetId       String // 挂 ReportTarget(非 unique)
  seq            Int // 该 target 下第几次提交(1-based,发号)
  invoiceNo      String // 发票号
  purchaseDate   DateTime // 购买日期
  unitOrgId      String? // 单位 org id(松引用)
  unitName       String? // 单位名称快照
  totalAmountCents Int     @default(0) // 冗余 = SUM(lines.amountCents),单位=分;列表/校验
  invoiceFileId  String? // ★共享发票文件(头层一份)
  contractFileId String? // ★共享合同文件(头层一份)
  headData       String    @default("{}") // 头层其余模板自由字段 JSON(明细不进这里)
  status         String    @default("draft") // draft | submitted | returned | approved
  submittedById  String?
  submittedAt    DateTime?
  reviewNote     String?
  reviewedById   String?
  reviewedAt     DateTime?
  returnCount    Int       @default(0)
  createdAt      DateTime  @default(now())
  updatedAt      DateTime  @updatedAt

  lines ReportLine[]

  @@unique([targetId, seq]) // 发号防并发重号(仿 certificate 批次)
  @@unique([taskId, targetId, invoiceNo]) // 防同对象重录同一发票号
  @@index([taskId])
  @@index([targetId])
  @@index([status])
}

// @module: report
// ★原子单位 = 一行结构化记录 = 一条发票明细。可聚合度量(amount/feeSource/orgId/category)抽成真实列。
// 点选清单带出的产品字段快照落库(次年换清单不污染历史);catalogItemId 仅溯源。
model ReportLine {
  id            String           @id @default(cuid())
  submissionId  String
  submission    ReportSubmission @relation(fields: [submissionId], references: [id], onDelete: Cascade)
  taskId        String // 冗余,便于跨提交 SQL 聚合
  orgId         String? // 冗余 = 对象单位(便于 group-by)
  lineNo        Int
  catalogItemId String? // 松引用 ReportCatalogItem(仅溯源)
  // 点选带出的清单只读快照列(年度调整不污染历史;税率/起订量/联系方式等其余清单字段存 extraJson.catalog 保完整)
  productName    String
  spec           String? // 规格(清单快照,如「5L」「200g*2」)
  category       String? // 第一~第四部分
  categoryDesc   String?
  recommendOrg   String? // 推荐单位
  origin         String? // 产地
  catalogSupplier String? // 清单供应商(扶贫目录里该产品的供货商,快照;区别于发票销售方)
  unitPriceCents Int? // 企业采购价快照(单位=分)
  // 录入度量列(可 SQL group-by;金额一律存「分」避免浮点误差,UI 除以 100 显示)
  amountCents   Int // 购买金额(单位=分)
  feeSource     String // ★费用来源(福利费|工会经费),逐行独立
  supplier      String? // 销售方(发票识别的实际销售单位,一票一个 → 冗余到每行便于按销售方 group-by)
  qty           Int?
  extraJson     String           @default("{}") // 其余动态列(含 catalog:{taxRate,minOrderQty,contact} 清单完整快照)

  @@index([submissionId])
  @@index([taskId, orgId])
  @@index([taskId, feeSource])
  @@index([taskId, category])
  @@index([taskId, supplier])
  @@index([taskId, catalogSupplier])
  @@index([catalogItemId])
}

// @module: report
// 目录(清单)— 一批可点选商品(如「2026帮扶产品清单」3988 行)。columnsJson 驱动 catalog_pick 带出哪些列。
model ReportCatalog {
  id          String              @id @default(cuid())
  catalogTag  String              @unique // 'fupin-2026'
  name        String // '2026帮扶产品清单'
  year        Int?
  columnsJson String              @default("[]") // 列定义
  active      Boolean             @default(true)
  createdAt   DateTime            @default(now())
  items       ReportCatalogItem[]

  @@index([active])
}

// @module: report
// 清单一行(3988 行)。批量整体导入,一年一调,轻量维护。
model ReportCatalogItem {
  id            String        @id @default(cuid())
  catalogTag    String // 冗余,便于按 tag 检索
  catalogId     String
  catalog       ReportCatalog @relation(fields: [catalogId], references: [id], onDelete: Cascade)
  totalSeq      Int? // 总序号
  subSeq        Int? // 分序号
  productName   String
  spec          String? // 产品规格
  purchasePriceCents Int? // 企业采购价(单位=分)
  taxRate       String? // 税率
  minOrderQty   String? // 起订量
  contact       String? // 联系方式
  category      String // 第一~第四部分
  categoryDesc  String? // 类别说明
  supplier      String? // 供应商
  recommendOrg  String? // 推荐单位
  origin        String? // 产地
  dataJson      String        @default("{}") // 其余列

  @@index([catalogTag, category])
  @@index([catalogTag, productName])
}

// @module: report
// 派发对象「快捷组」—— 每人自己存的常用单位组合,跟个人账号走(服务端持久化,跨浏览器/设备/客户端)。
// 列全用 String(含 createdAt 存 ISO 串)避开 SQLite DateTime 写入坑;服务端用 raw SQL 读写。
model ReportUnitGroup {
  id         String @id @default(cuid())
  userId     String // 松引用 User
  name       String
  orgIdsJson String @default("[]") // 选中单位 org id 数组 JSON
  createdAt  String @default("") // ISO 时间串(排序用)

  @@index([userId])
}

// ─────────────────────────────────────────────────────────
// 知识分享平台 (knowledge)
// 三个正交维度:领域分类(党建/设备/安全,两级树)× 内容类型(条例/制度/经验/操作指南,
// 审核开关挂这里)× 标签(tagsJson 自由维度)。制度支持版本链(versionGroupId)。
// 设计规格:docs/specs/2026-07-05-knowledge-platform.md
// ─────────────────────────────────────────────────────────

// 领域分类(党建/设备/安全…)。两级:parentId=null 为顶级;深度≤2 与同级重名
// 由 service 校验(PG 的 UNIQUE 对 parentId=NULL 的行不生效,复合唯一约束靠不住)。
// @module: knowledge
model KnowledgeCategory {
  id          String              @id @default(cuid())
  name        String
  parentId    String?
  parent      KnowledgeCategory?  @relation("KnowledgeCategoryTree", fields: [parentId], references: [id], onDelete: Restrict)
  children    KnowledgeCategory[] @relation("KnowledgeCategoryTree")
  description String?
  icon        String? // lucide 图标名(IconPicker)
  sortOrder   Int                 @default(0)
  createdAt   DateTime            @default(now())
  updatedAt   DateTime            @updatedAt

  articles KnowledgeArticle[]

  @@index([parentId, sortOrder])
}

// 内容类型 + 审核开关(「按内容类型可配审核」的唯一开关处:条例/制度默认需审,
// 经验分享/操作指南直发)。管理员可增改;code 被文章松引用,删除前 service 校验无文章。
// @module: knowledge
model KnowledgeType {
  code          String   @id // regulation | policy | experience | guide | 自定义
  name          String
  requireReview Boolean  @default(false)
  sortOrder     Int      @default(0)
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt
}

// 知识文章。contentMd 直接存库(PG text,ILIKE 全文搜索 + AI 处理都在库内);
// 正文图片/附件走 storage 只留引用(图片引用烤在 contentMd 里,GC 靠正则扫)。
// 版本链:versionGroupId 相同 = 同一制度的多个版本;发布新版时旧版转 archived
// (不进列表/搜索,详情页「历史版本」可查)。
// @module: knowledge
model KnowledgeArticle {
  id             String            @id @default(cuid())
  title          String
  categoryId     String
  category       KnowledgeCategory @relation(fields: [categoryId], references: [id], onDelete: Restrict)
  typeCode       String // → KnowledgeType.code(松引用,service 校验存在)
  contentMd      String // Markdown 正文
  summary        String? // AI 导读(人工可改)
  faqJson        String? // 常见问题 [{id,q,a,clicks,pinned}] JSON 串(clicks 点击热度 / pinned 人工置顶)
  tagsJson       String? // 标签 ["党务","入党"] JSON 串(轻量,不建 Tag 表)
  level          String? // 内容级别 code(national/group/region/company/branch,见 knowledge.constants KNOWLEDGE_LEVELS)
  maintainersJson String? // 指派的维护人员 [{userId,userName}] JSON 串(作者/管理员指派,维护人可编辑本文,松引用 User)
  versionGroupId String? // 版本链 id:首版=自身 id;修订版=旧文章的 versionGroupId ?? 旧文章 id
  versionLabel   String? // 版本说明,如「2026年修订」
  status         String            @default("draft") // draft | pending | published | rejected | archived
  rejectReason   String?
  source         String            @default("manual") // manual | import | ai_archive
  sourceUrl      String? // ai_archive 的原文链接
  authorId       String // 松引用 User.id
  authorName     String // 快照
  reviewedById   String?
  reviewedByName String?
  reviewedAt     DateTime?
  publishedAt    DateTime?
  pinned         Boolean           @default(false)
  coverFileId    String? // 松引用 StoredFile(列表卡片封面,可空)
  viewCount      Int               @default(0) // 冗余计数列,原子 increment
  likeCount      Int               @default(0)
  favoriteCount  Int               @default(0)
  commentCount   Int               @default(0)
  createdAt      DateTime          @default(now())
  updatedAt      DateTime          @updatedAt

  attachments KnowledgeAttachment[]
  comments    KnowledgeComment[]
  reactions   KnowledgeReaction[]
  feedbacks   KnowledgeFeedback[]

  @@index([categoryId, status])
  @@index([status, pinned, publishedAt])
  @@index([authorId, status])
  @@index([versionGroupId])
}

// 展示型附件(模板下载/视频等,阅读页附件卡);正文内嵌图片不入此表。
// @module: knowledge
model KnowledgeAttachment {
  id            String           @id @default(cuid())
  articleId     String
  article       KnowledgeArticle @relation(fields: [articleId], references: [id], onDelete: Cascade)
  fileId        String // 松引用 StoredFile
  name          String // 展示名(默认原始文件名)
  size          Int              @default(0)
  downloadCount Int              @default(0)
  sortOrder     Int              @default(0)
  createdAt     DateTime         @default(now())

  @@index([articleId])
}

// 评论:单层 + replyToId(@回复)。content 纯文本渲染(零 XSS 面);
// replyToId 松引用同文章另一条评论,被回复删除时前端显示「原评论已删除」。
// @module: knowledge
model KnowledgeComment {
  id              String           @id @default(cuid())
  articleId       String
  article         KnowledgeArticle @relation(fields: [articleId], references: [id], onDelete: Cascade)
  userId          String // 松引用 User.id
  userName        String // 快照
  content         String
  replyToId       String?
  replyToUserName String?
  createdAt       DateTime         @default(now())

  @@index([articleId, createdAt])
}

// 点赞/收藏(type 区分),一人一文一类型一条。
// @module: knowledge
model KnowledgeReaction {
  id        String           @id @default(cuid())
  articleId String
  article   KnowledgeArticle @relation(fields: [articleId], references: [id], onDelete: Cascade)
  userId    String // 松引用 User.id
  type      String // like | favorite
  createdAt DateTime         @default(now())

  @@unique([userId, articleId, type])
  @@index([articleId, type])
  @@index([userId, type, createdAt])
}

// 吐槽 = 不公开的意见反馈通道(与评论分开):仅作者与管理员可见并回复。
// userId 始终存(防刷/审计),anonymous 只影响展示(对作者与管理员均显「匿名用户」)。
// @module: knowledge
model KnowledgeFeedback {
  id        String           @id @default(cuid())
  articleId String
  article   KnowledgeArticle @relation(fields: [articleId], references: [id], onDelete: Cascade)
  userId    String // 松引用 User.id
  userName  String // 快照
  anonymous Boolean          @default(false)
  content   String
  status    String           @default("open") // open | replied | closed
  createdAt DateTime         @default(now())
  updatedAt DateTime         @updatedAt

  replies KnowledgeFeedbackReply[]

  @@index([articleId, status])
  @@index([status, createdAt])
}

// 反馈回复(作者或管理员,实名)。
// @module: knowledge
model KnowledgeFeedbackReply {
  id         String            @id @default(cuid())
  feedbackId String
  feedback   KnowledgeFeedback @relation(fields: [feedbackId], references: [id], onDelete: Cascade)
  userId     String // 松引用 User.id
  userName   String // 快照
  content    String
  createdAt  DateTime          @default(now())

  @@index([feedbackId])
}

// 原始浏览日志(量级 ~几千行/天,PG 带索引聚合无压力,不建日聚合表)。
// articleId 松引用(删文留日志,统计口径需要);durationSec 由离开时 beacon 回填
// (取 max 幂等,封顶 14400 秒 = 4h)。
// @module: knowledge
model KnowledgeViewLog {
  id          String   @id @default(cuid())
  articleId   String // 松引用 KnowledgeArticle(不建 FK,删文留日志)
  userId      String // 松引用 User.id
  durationSec Int      @default(0)
  createdAt   DateTime @default(now())

  @@index([articleId, createdAt])
  @@index([userId, createdAt])
}

// 文章模板(正文框架复用):人人可「存为模板」,别人新建时套用其 contentMd 框架。
// @module: knowledge
model KnowledgeTemplate {
  id            String   @id @default(cuid())
  name          String
  description   String?
  contentMd     String // 正文框架
  createdById   String // 松引用 User.id
  createdByName String // 快照
  createdAt     DateTime @default(now())

  @@index([createdAt])
}

// ═══════════════ 先锋晒场(擂台型晒实绩:晒台 + 参晒作品 + 互动) ═══════════════

// 晒场分类(六大先锋榜:业绩/安全/实事/幸福/风貌/人物,seed 预置固定 id,管理员可增改)
// @module: showcase
model ShowcaseCategory {
  id          String   @id @default(cuid())
  name        String
  description String?
  icon        String? // lucide 图标名(IconPicker)
  sortOrder   Int      @default(0)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  stages ShowcaseStage[]

  @@index([sortOrder])
}

// 晒台 = 一次擂台(如「晒安全行驶里程」):台主发起 → 管理员审核上架 → 开放参晒 → 台内排位。
// introBlocksJson = 台头介绍区块,与作品 blocksJson 同一套展示工具注册表(showcase-blocks.ts)。
// rankBy=metric 时 metric* 四件套生效;**有作品后禁改 rankBy/metric***(防旧作品申报值失义)。
// @module: showcase
model ShowcaseStage {
  id              String           @id @default(cuid())
  title           String
  categoryId      String
  category        ShowcaseCategory @relation(fields: [categoryId], references: [id], onDelete: Restrict)
  intro           String? // 一段话简介(列表卡)
  rulesMd         String? // 比拼规则(markdown)
  introBlocksJson String? // 台头介绍区块 [{id,type,content}](≤10 块)
  templateJson    String           @default("[]") // 填报规则=区块模板 [{id,type,title,requirement?}]:台主定规则,参晒人逐块照填(有作品后禁改)
  coverFileId     String? // 松引用 StoredFile
  rankBy          String           @default("likes") // likes(按作品点赞)| metric(按申报数值)
  metricLabel     String? // 比拼指标名(如「安全行驶里程」)
  metricUnit      String? // 单位(如「万公里」)
  metricDecimals  Int              @default(0) // 小数位 0..4
  metricOrder     String           @default("desc") // desc | asc
  status          String           @default("draft") // draft | pending | published | rejected | closed
  rejectReason    String?
  ownerId         String // 台主,松引用 User.id
  ownerName       String // 快照
  reviewedById    String?
  reviewedByName  String?
  reviewedAt      DateTime?
  publishedAt     DateTime?
  closedAt        DateTime? // closed = 停止收稿、榜单定格、仍可浏览
  pinned          Boolean          @default(false)
  viewCount       Int              @default(0) // 冗余计数列,原子 increment
  likeCount       Int              @default(0)
  entryCount      Int              @default(0) // 已公开作品数(作品过审 +1 / 公开作品被删 -1)
  createdAt       DateTime         @default(now())
  updatedAt       DateTime         @updatedAt

  entries ShowcaseEntry[]

  @@index([categoryId, status])
  @@index([status, pinned, publishedAt])
  @@index([ownerId, status])
}

// 参晒作品:所有登录用户可提交;台主或管理员审核后公开(本人=台主/管理员免审);
// published 被**作者**再编辑 → 回 pending 重审(防赛后篡改申报值;台主/管理员代改不回炉)。
// @module: showcase
model ShowcaseEntry {
  id             String        @id @default(cuid())
  stageId        String
  stage          ShowcaseStage @relation(fields: [stageId], references: [id], onDelete: Cascade)
  title          String
  summary        String? // 一句话说明
  coverFileId    String? // 松引用 StoredFile
  blocksJson     String        @default("[]") // 展示区块 [{id,type,content}](≤30 块)
  metricValue    Float? // 申报数值(台 rankBy=metric 时提交必填)
  status         String        @default("draft") // draft | pending | published | rejected
  rejectReason   String?
  authorId       String // 松引用 User.id
  authorName     String // 快照
  reviewedById   String?
  reviewedByName String?
  reviewedAt     DateTime?
  publishedAt    DateTime?
  viewCount      Int           @default(0)
  likeCount      Int           @default(0)
  createdAt      DateTime      @default(now())
  updatedAt      DateTime      @updatedAt

  @@index([stageId, status, likeCount])
  @@index([stageId, status, metricValue])
  @@index([authorId, status])
}

// 点赞(多态:晒台/作品两级)。唯一约束 = 「每个账户对同一对象只能点一次」的地基;
// targetId 松引用(多态无 FK,删对象由 service 联动清);计数冗余在各自主表,事务内 increment。
// @module: showcase
model ShowcaseReaction {
  id         String   @id @default(cuid())
  targetType String // stage | entry
  targetId   String
  userId     String // 松引用 User.id
  type       String   @default("like")
  createdAt  DateTime @default(now())

  @@unique([userId, targetType, targetId, type])
  @@index([targetType, targetId, type])
  @@index([userId, type, createdAt])
}

// 吐槽 = 不公开意见反馈(多态):仅台主(stage)/作者(entry)与管理员可见并回复。
// userId 始终存(防刷/审计),anonymous 只影响展示。
// @module: showcase
model ShowcaseFeedback {
  id         String   @id @default(cuid())
  targetType String // stage | entry
  targetId   String // 松引用(多态无 FK,删对象留吐槽,列表显「已删除」)
  userId     String // 松引用 User.id
  userName   String // 快照
  anonymous  Boolean  @default(false)
  content    String
  status     String   @default("open") // open | replied | closed
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  replies ShowcaseFeedbackReply[]

  @@index([targetType, targetId, status])
  @@index([status, createdAt])
}

// 吐槽回复(台主/作者或管理员,实名)。
// @module: showcase
model ShowcaseFeedbackReply {
  id         String           @id @default(cuid())
  feedbackId String
  feedback   ShowcaseFeedback @relation(fields: [feedbackId], references: [id], onDelete: Cascade)
  userId     String // 松引用 User.id
  userName   String // 快照
  content    String
  createdAt  DateTime         @default(now())

  @@index([feedbackId])
}

// 浏览日志(多态,删对象留日志);durationSec 由离开时 beacon 回填(取 max 幂等,封顶 4h)。
// @module: showcase
model ShowcaseViewLog {
  id          String   @id @default(cuid())
  targetType  String // stage | entry
  targetId    String // 松引用
  userId      String // 松引用 User.id
  durationSec Int      @default(0)
  createdAt   DateTime @default(now())

  @@index([targetType, targetId, createdAt])
  @@index([userId, createdAt])
}

// ═══════════════ 现场互动(大屏 + 手机扫码遥控:活动 → 游戏 → 局)═══════════════
//
// 一场活动 = 一块大屏 = 一个房间码。活动里放多个游戏(节目单),每个游戏跑多局(如摇奖摇多次)。
// 运行态(当前词/倒计时/抢答锁/计数)只活在后端内存(room-session.service),活动结束即弃;
// 这里只落「开过什么活动 + 每局结算快照」的审计线。观众匿名(仅昵称 + 客户端生成 deviceId,
// 断线重连凭此恢复身份)。均 JSON 存 String、跨模块 userId 松引用不建外键,守 PG 系国产库兼容 + DAG。

// 活动:有 interactive:manage 者创建;roomCode 大屏显示 + 手机扫码/输码入房。
// @module: interactive
model InteractiveEvent {
  id            String    @id @default(cuid())
  roomCode      String    @unique // 6 位大写房间码,手机扫码/输码入房
  title         String
  status        String    @default("draft") // draft | live | ended
  configJson    String    @default("{}") // 活动级通用配置快照(队伍/主题/BGM 等)
  createdById   String // 松引用 User.id(创建者=owner)
  createdByName String // 快照
  createdAt     DateTime  @default(now())
  startedAt     DateTime?
  endedAt       DateTime?

  managers InteractiveManager[]
  players  InteractivePlayer[]
  games    InteractiveGame[]

  @@index([createdById, status])
  @@index([status])
}

// 共管人:创建者邀请的其他管理人员(逐场授权,不需全局权限点);owner=创建者本人。
// @module: interactive
model InteractiveManager {
  id        String           @id @default(cuid())
  eventId   String
  event     InteractiveEvent @relation(fields: [eventId], references: [id], onDelete: Cascade)
  userId    String // 松引用 User.id
  userName  String // 快照
  role      String           @default("collaborator") // owner | collaborator
  createdAt DateTime         @default(now())

  @@unique([eventId, userId])
  @@index([userId])
}

// 玩家:观众扫码进活动一次,跨游戏保留身份/队伍/累计;deviceId=客户端生成,断线重连凭此恢复。
// @module: interactive
model InteractivePlayer {
  id         String           @id @default(cuid())
  eventId    String
  event      InteractiveEvent @relation(fields: [eventId], references: [id], onDelete: Cascade)
  deviceId   String // 客户端 localStorage cuid,匿名身份
  nickname   String
  avatar     String? // 头像:"p:<idx>"=预设头像 / "f:<fileId>"=手机上传(storage 松引用)
  teamId     String? // 组队模式所属队(队定义在节目 configJson.grouping)
  teamName   String?
  joinedAt   DateTime         @default(now())
  lastSeenAt DateTime         @default(now())

  @@unique([eventId, deviceId])
  @@index([eventId])
}

// 游戏:一场活动里的一个游戏(节目单一项);configJson=该游戏规则快照;gameType 对应双端注册表键。
// @module: interactive
model InteractiveGame {
  id         String           @id @default(cuid())
  eventId    String
  event      InteractiveEvent @relation(fields: [eventId], references: [id], onDelete: Cascade)
  gameType   String // 'tap_race' | 'guess_draw' | 'shake' | 'buzzer' | 'wheel' ...
  title      String
  orderIdx   Int              @default(0) // 节目单顺序
  configJson String           @default("{}") // GameDef.Config 快照(经 validateConfig 归一化)
  status     String           @default("pending") // pending | active | done
  createdAt  DateTime         @default(now())

  rounds InteractiveRound[]

  @@index([eventId, orderIdx])
}

// 局:一个游戏跑多局(摇奖摇多次、抢答一题一局);resultJson=该局结算快照。
// @module: interactive
model InteractiveRound {
  id         String          @id @default(cuid())
  gameId     String
  game       InteractiveGame @relation(fields: [gameId], references: [id], onDelete: Cascade)
  seq        Int // 本游戏第几局
  status     String          @default("running") // running | ended
  resultJson String? // 结算快照 Settlement(ended 时写)
  startedAt  DateTime        @default(now())
  endedAt    DateTime?

  @@index([gameId])
}
