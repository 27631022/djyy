// 党建益友 平台底座 Prisma Schema
//
// 开发期 SQLite,生产切 Postgres 只需把 provider 改成 "postgresql"
// 注意:模型已避开 SQLite 不支持的类型 (enum / array / native JSON),
// 切换 Postgres 时迁移可直接生成,模型本身无需改动。

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

// ─────────────────────────────────────────────────────────
// 组织 (双体系并行:党组织 + 行政机构,各自支持真实组织与虚拟组织)
// ─────────────────────────────────────────────────────────
// kind 取值:
//   party       党组织
//   admin       行政机构
//
// type 在 kind 范围内取值:
//   kind=party : committee(党委) | general(党总支) | branch(党支部) | group(党小组)
//   kind=admin : corp(集团) | company(公司) | dept(部门) | team(班组)
//
// isVirtual:
//   false (默认)  实体组织,层级隶属固定,人员归属相对稳定
//   true          虚拟组织 (专班/项目组/学习小组等),临时性、跨部门、人员可灵活进出
//
// 一个用户可以同时归属任意多个组织 (含虚拟和真实),由 UserOrganization 表的复合主键
// [userId, orgId] 保证唯一性。isPrimary 标记其主归属。
// @module: organization
model Organization {
  id        String         @id @default(cuid())
  name      String
  code      String         @unique
  kind      String // party | admin
  type      String // 见上方注释
  isVirtual Boolean        @default(false) // 虚拟组织标记
  parentId  String?
  parent    Organization?  @relation("OrgTree", fields: [parentId], references: [id])
  children  Organization[] @relation("OrgTree")
  sortOrder Int            @default(0)
  active    Boolean        @default(true)
  meta      String? // 扩展字段 JSON 串 (SQLite 无原生 JSON)
  createdAt DateTime       @default(now())
  updatedAt DateTime       @updatedAt

  memberships UserOrganization[]
  scopedBy    UserRoleScope[]

  @@index([kind])
  @@index([isVirtual])
}

// ─────────────────────────────────────────────────────────
// 用户
// ─────────────────────────────────────────────────────────
// @module: user
model User {
  id           String   @id @default(cuid())
  username     String   @unique // 员工编号 / 登录名
  name         String // 显示名
  email        String?  @unique
  phone        String?
  avatarUrl    String?
  active       Boolean  @default(true)
  externalId   String?  @unique // Casdoor 等外部 IdP 的 sub
  // 自定义字段值 (基于 UserCustomField 定义)
  // JSON 字符串,结构: { [fieldCode]: stringValue, ... }
  // 例: '{"hire_date":"2020-03-15","education":"bachelor","id_card_no":"110..."}'
  // 字段缺失=未填,空字符串=已清空
  customFields String?
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  memberships  UserOrganization[]
  roles        UserRole[]
  certificates Certificate[] // V2:作为持证人的已发证书
}

// 用户 ↔ 组织 多对多 (一人可挂多个组织,但只能有一个 primary)
// @module: user
model UserOrganization {
  userId    String
  orgId     String
  user      User         @relation(fields: [userId], references: [id], onDelete: Cascade)
  org       Organization @relation(fields: [orgId], references: [id], onDelete: Cascade)
  isPrimary Boolean      @default(false)
  position  String? // 兼任职务,如 "支部书记"
  joinedAt  DateTime     @default(now())

  @@id([userId, orgId])
  @@index([orgId])
}

// ─────────────────────────────────────────────────────────
// 角色 / 权限 (RBAC + 数据范围)
// ─────────────────────────────────────────────────────────
// @module: role
model Role {
  id          String   @id @default(cuid())
  code        String   @unique // party_secretary | admin | member ...
  name        String // 显示名,如 "党委书记"
  description String?
  builtin     Boolean  @default(false) // 内置角色不允许删除
  createdAt   DateTime @default(now())

  users       UserRole[]
  permissions RolePermission[]
}

// 用户 ↔ 角色,并附带数据范围 (4 级权限模型中的"数据权限")
// scope 取值 (通用化,与组织 kind 解耦,行政/党组织均适用):
//   self     仅本人
//   own      仅本组织直接成员 (不含子组织)
//   subtree  本组织 + 所有下级
//   all      全平台
//   custom   自定义子树集合,具体范围由 scopeOrgs 关联表的多条记录定义 (允许多个子树并集)
//
// 字段调整说明:
//   原 scopeOrgId 单值字段已删除,改为通过 UserRoleScope 关联表表达"一个用户在某角色下可见的多棵子树"。
//   primary key 从 [userId, roleId] 复合主键改为自增 id,以便 UserRoleScope 通过外键引用。
// @module: role
model UserRole {
  id        String          @id @default(cuid())
  userId    String
  roleId    String
  user      User            @relation(fields: [userId], references: [id], onDelete: Cascade)
  role      Role            @relation(fields: [roleId], references: [id], onDelete: Cascade)
  scope     String          @default("self")
  scopeOrgs UserRoleScope[]
  grantedAt DateTime        @default(now())

  @@unique([userId, roleId])
  @@index([roleId])
}

// 用户角色数据范围 (scope=custom 时使用)
// 一条 UserRole 可以关联 0..N 个组织,代表"该用户用此角色看哪些子树"。
// 例:某副总在 'dept_manager' 角色下 scope=custom,scopeOrgs 同时指向 IT 中心 + 业务发展部,
//      表示他能管理这两个部门的人员/数据。
//
// scope ∈ {self, own, subtree, all} 时 scopeOrgs 应为空。
// @module: role
model UserRoleScope {
  userRoleId String
  orgId      String
  userRole   UserRole     @relation(fields: [userRoleId], references: [id], onDelete: Cascade)
  org        Organization @relation(fields: [orgId], references: [id], onDelete: Cascade)
  createdAt  DateTime     @default(now())

  @@id([userRoleId, orgId])
  @@index([orgId])
}

// 权限点
// category 取值:
//   menu       菜单可见
//   operation  操作 (按钮/接口)
//   field      字段访问
//   data       数据权限 (作为标记,实际范围由 UserRole.scope 控制)
// @module: permission
model Permission {
  id          String   @id @default(cuid())
  code        String   @unique // certificate:issue / user:read ...
  name        String
  description String?
  category    String // menu | operation | field | data
  pluginName  String? // 来源插件 (null 表示平台自有)
  builtin     Boolean  @default(false)
  createdAt   DateTime @default(now())

  roles RolePermission[]
}

// @module: role (junction; permission 模块只读)
model RolePermission {
  roleId       String
  permissionId String
  role         Role       @relation(fields: [roleId], references: [id], onDelete: Cascade)
  permission   Permission @relation(fields: [permissionId], references: [id], onDelete: Cascade)

  @@id([roleId, permissionId])
}

// ─────────────────────────────────────────────────────────
// 数据字典 (统一管理下拉枚举值,避免硬编码 + 输入混乱)
// ─────────────────────────────────────────────────────────
// 典型使用场景:
//   admin_position    行政职务   (经理 / 主管 / 工程师 / 干事 ...)
//   party_position    党组织职务 (党员 / 支部书记 / 党委委员 ...)
//   user_education    学历      (大专 / 本科 / 硕士 ...)
//   ...
//
// 任何下拉框都可以引用 Dictionary.code 拉取 DictItem 列表填充。
// 后续用户自定义字段 (UserCustomFieldDef) 在 type='select' 时也通过 dictCode 关联到这里。
// @module: dictionary
model Dictionary {
  id          String   @id @default(cuid())
  code        String   @unique // 字典代码,如 'admin_position'
  name        String // 显示名,如 '行政职务'
  description String?
  builtin     Boolean  @default(false) // 内置字典 (核心业务依赖,不允许删除)
  sortOrder   Int      @default(0)
  active      Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  items DictItem[]

  @@index([active])
}

// 字典项 — 支持 2 级分类
//   parentId=null  根级项,作为"分类"使用 (如 管理类 / 技术类 / 操作类)
//   parentId≠null  二级项,可被业务字段实际选用 (如 经理 / 工程师 / 专员)
// 强制 2 级:parent 必须自身是根级 (parentId=null)
// 兼容:parentId 留空可作 1 级扁平字典使用 (如 学历 / 政治面貌)
// @module: dictionary
model DictItem {
  id          String     @id @default(cuid())
  dictId      String
  dict        Dictionary @relation(fields: [dictId], references: [id], onDelete: Cascade)
  parentId    String?
  parent      DictItem?  @relation("DictItemTree", fields: [parentId], references: [id], onDelete: Cascade)
  children    DictItem[] @relation("DictItemTree")
  code        String // 项代码 (组内唯一)
  label       String // 显示文字
  description String?
  sortOrder   Int        @default(0)
  active      Boolean    @default(true)
  createdAt   DateTime   @default(now())
  updatedAt   DateTime   @updatedAt

  @@unique([dictId, code])
  @@index([dictId])
  @@index([parentId])
}

// ─────────────────────────────────────────────────────────
// 用户自定义字段 (元数据驱动表单)
// ─────────────────────────────────────────────────────────
// 由管理员在 /admin/system/custom-fields 维护,User.customFields 实际值依此校验和渲染。
//
// type 取值:
//   text       单行文本
//   number     数字 (前端 type=number,后端仍存 string)
//   date       日期 (YYYY-MM-DD 字符串)
//   textarea   多行文本
//   select     从 dictCode 指定的字典中选择,存字典项 code (而非 label,允许字典 label 变更)
//
// 添加新字段对已有用户无破坏:user.customFields[新code] 暂为空即可,加载/保存均忽略缺失字段。
// 字段被删除或禁用:对应用户值保留在 customFields 里但不再展示。
// @module: user-custom-field
model UserCustomField {
  id          String   @id @default(cuid())
  code        String   @unique // hire_date / education / id_card_no
  label       String // 入职日期 / 学历 / 身份证号
  type        String // text | number | date | textarea | select
  dictCode    String? // type=select 时引用 Dictionary.code
  placeholder String?
  description String? // 输入框下方帮助文字
  required    Boolean  @default(false)
  sortOrder   Int      @default(0)
  active      Boolean  @default(true)
  builtin     Boolean  @default(false) // 内置字段不允许删除
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@index([active, sortOrder])
}

// ─────────────────────────────────────────────────────────
// 首页导航 (6 大分类 + 项目两级结构)
// ─────────────────────────────────────────────────────────
// NavPage 的 "全部导航" 区域由这两张表驱动。
//
// icon 字段存 lucide-react 图标的 PascalCase 名称(如 "BookOpenIcon"),
// 前端运行时通过 `(lucide as any)[item.icon]` 解析为组件。
//
// color 字段存 hex/rgb 字符串,作为该分类/项目的视觉主色。这是"分类色",
// 与主题色解耦 —— 不同分类用不同颜色区分(党务红、学习橙、统计蓝...)。
// @module: nav-category
model NavCategory {
  id        String   @id @default(cuid())
  code      String   @unique // 程序内标识,如 'party-affairs'
  label     String // 显示名,如 '党务办理'
  color     String // 分类主色 hex,如 '#C8001E'
  bgLight   String // 配套淡色背景 hex,如 '#FFF5F5'
  icon      String // lucide 图标名,如 'ClipboardListIcon'
  sortOrder Int      @default(0)
  active    Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  items NavItem[]

  @@index([active, sortOrder])
}

// @module: nav-category
model NavItem {
  id         String      @id @default(cuid())
  categoryId String
  category   NavCategory @relation(fields: [categoryId], references: [id], onDelete: Cascade)
  icon       String // lucide 图标名
  label      String // 显示名,如 '党费缴纳'
  color      String // 项目色 hex
  url        String? // 点击跳转 URL(站内 /plugins/... 或外链)
  common     Boolean     @default(false) // 是否常用(打 "常用" 标 + 出现在快捷条)
  desc       String? // 一行描述
  likes      Int         @default(0) // 点赞数(后续接真实统计)
  views      Int         @default(0) // 浏览数
  sortOrder  Int         @default(0)
  active     Boolean     @default(true)
  createdAt  DateTime    @default(now())
  updatedAt  DateTime    @updatedAt

  @@index([categoryId, sortOrder])
  @@index([active])
}

// ─────────────────────────────────────────────────────────
// 站点设置 (品牌/首页文案/页脚/主题色 等)
// ─────────────────────────────────────────────────────────
// 单例表:全表只有一行,id 固定为 "default"。
// data 字段存 JSON 字符串,前后端共享 TypeScript 类型 SiteSettingsData。
//
// 选择 JSON 而非每个字段一列的理由:
//   1. 字段以后会持续增加 (页脚链接、导航菜单、配色、字号缩放等),用 JSON 加字段不需要 migrate
//   2. 前后端契约由 TS 类型管,而不是数据库 schema
//   3. 单例表只有 GET / PUT,无需复杂查询和索引
//
// 前台 (NavPage) 通过公开接口 GET /site-settings 获取;后台 (管理员) 通过 PUT /site-settings 更新。
// @module: site-setting
model SiteSetting {
  id        String   @id // 固定 "default"
  data      String // JSON 字符串
  updatedAt DateTime @updatedAt
}

// ─────────────────────────────────────────────────────────
// 审计日志
// ─────────────────────────────────────────────────────────
// 平台关键写操作 (角色/组织/权限变更) 与敏感读操作通过 AuditService.log()
// 落入此表。前端 /admin/audit 页面只读浏览。
//
// action 命名约定:domain.verb
//   org.create / org.update / org.move / org.delete
//   user.create / user.update / user.deactivate
//   role.grant / role.revoke / role.update
//   plugin.install / plugin.enable / plugin.disable
//   auth.login / auth.logout
//
// detail 存 JSON 串,记录改动前后差异或额外上下文。
// @module: audit
model AuditLog {
  id         String   @id @default(cuid())
  actorId    String? // 操作者 user id
  actorName  String? // 冗余姓名,actor 被删后仍可读
  action     String // 见上方命名约定
  target     String? // 目标资源 ID
  pluginName String? // 来源插件 (null = 平台自有)
  detail     String? // JSON 串
  ip         String? // 操作来源 IP
  createdAt  DateTime @default(now())

  @@index([createdAt])
  @@index([actorId])
  @@index([action])
  @@index([pluginName])
}

// ─────────────────────────────────────────────────────────
// 外部 API 接入(LLM / 短信 / 邮件 / 对象存储 / ...)
// ─────────────────────────────────────────────────────────
// 管理员在「系统设置 → 外部 API」录入 apiKey/apiUrl/model,
// 应用层(如 extraction.service)通过 ExternalApiService.getKeyForProvider(code)
// 读取:DB 优先 → .env 兜底 → null。
//
// provider 命名约定:小写英文/数字/横线,如:
//   deepseek / openai / qwen / doubao / ernie / claude
//   sms-aliyun / sms-tencent / email-smtp / oss-aliyun
//
// apiKey 在 DB 明文存(单机 dev 阶段 OK,生产建议加 AES-GCM 加密 + KMS)。
// API 响应里始终脱敏 (前 4 + 后 4,中间 ***)。
// @module: external-api
model ExternalApi {
  id           String   @id @default(cuid())
  provider     String   @unique // 平台标识,如 'deepseek'
  name         String // 显示名,如 'DeepSeek 大模型'
  description  String?
  apiKey       String? // 明文密钥
  apiUrl       String? // 自定义 endpoint
  model        String? // 默认文本模型
  visionModel  String? // 多模态/视觉模型(OCR 用)。空 = 走 model 兜底
  rechargeUrl  String? // 平台充值/计费控制台 URL
  priority     Int      @default(50) // 业务优先级,大者优先。getActive*() 按此降序选
  capabilities String   @default("chat") // 能力标签逗号分隔:chat/vision/reasoning
  active       Boolean  @default(true)
  meta         String? // JSON 扩展(超时/温度等)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  @@index([active])
  @@index([priority])
}

// ─────────────────────────────────────────────────────────
// 证书管理(V1:模板;V2:模板 + 发证 + 公开验证 + AI 提取)
// ─────────────────────────────────────────────────────────
// 一个 CertificateTemplate 就是「证书的可视化设计 + 变量字段定义」,
// designJson 序列化整个 DesignerState(elements 数组 + background +
// canvas 尺寸 + 变量字段),由前端 Canvas 设计器读写。
//
// V2:Certificate 表挂接发证记录,onDelete:Restrict 保护已发模板不被误删。
// honorCode 是 V2 加的:荣誉首字母代码(如 "QDJL" 庆典奖励),
// 用于证书编号生成 {年份}-{honorCode}-{batchTotal}-{batchSeq}。
// 一个模板 = 一种荣誉。
// @module: certificate
model CertificateTemplate {
  id          String   @id @default(cuid())
  name        String // 模板名,如"年度优秀党员证书"
  description String?
  category    String? // 分类:奖励/荣誉/培训... 留 null 即可
  honorCode   String? // V2:荣誉首字母代码,如 "QDJL"。发证时拷贝快照到 Certificate
  designJson  String // DesignerState 序列化(JSON 字符串)
  thumbnail   String? // 缩略图(data URL / base64),列表显示用
  width       Int      @default(800) // 画布宽 px
  height      Int      @default(566) // 画布高 px
  active      Boolean  @default(true) // 禁用不删
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  createdBy   String? // user id,可空

  certificates Certificate[] // V2 反向关联

  @@index([active])
  @@index([category])
}

// 已发证书 — V2 新增
// 编号 certNo 格式:{yearLabel}-{honorCode}-{batchTotal}-{batchSeq3位}
//   例:2024-QDJL-100-001
// batchKey = `${yearLabel}-${honorCode}-${batchTotal}`,同批次共享 → batchSeq 在批内 1..batchTotal
// 追加发证视为新批次(batchTotal 不同)
//
// source 取值:
//   internal  用本系统模板生成,有 templateId
//   external  上传的外部 PDF,templateId=null,externalFileData 存原文件
//
// pdfData / externalFileData 都是 base64 data URL。批量下载时后端拿来直接打 ZIP。
// V3 会改成对象存储,字段保留兼容。
// @module: certificate
model Certificate {
  id          String  @id @default(cuid())
  certNo      String  @unique // 完整证书编号,如 "2024-QDJL-100-001"
  yearLabel   String // 年份段,如 "2024" 或 "2024-2025"
  honorCode   String // 荣誉首字母快照
  batchKey    String // `${yearLabel}-${honorCode}-${batchTotal}` 同批次共享
  batchTotal  Int // 本批次总数
  batchSeq    Int // 批内序号,1-based
  publicToken String  @unique // 公开验证 URL token

  templateId String?
  template   CertificateTemplate? @relation(fields: [templateId], references: [id], onDelete: Restrict)

  // 持证人来源 + 关联 + 快照
  source          String  @default("internal") // internal | external
  // 荣誉类型(V3):individual | collective | unit
  //   individual:个人荣誉,recipientName=人名,可关联 User
  //   collective:集体荣誉,recipientName=集体名,自由文本
  //   unit:单位荣誉(如"先进基层党组织"),recipientName=单位名,自由文本
  // 老数据 null 兼容,前端按 individual 渲染
  honorType       String?
  recipientUserId String?
  recipientUser   User?   @relation(fields: [recipientUserId], references: [id], onDelete: SetNull)
  recipientName   String // 持证人姓名(必填,即使关联 User 也存快照)
  recipientEmpNo  String? // 员工编号快照(= User.username)
  recipientDept   String? // 部门快照
  recipientIdCard String? // 身份证号(可选)
  recipientPhone  String?

  // 变量值快照 — 发证时把表单值固化进来。即使后续改模板变量定义,本张还能还原
  variableData String // JSON 字符串,形如 { name: "张三", certNo: "...", ... }

  // 时间
  issueDate  DateTime  @default(now())
  validUntil DateTime? // 永久 = null

  // 发证人 + 机构(快照,审计需要)
  issuedBy       String // user id
  issuerName     String // 发证人姓名
  issuingOrgId   String? // Organization id(发证机构)
  issuingOrgName String?

  // 撤销
  revoked       Boolean   @default(false)
  revokedAt     DateTime?
  revokedReason String?
  revokedBy     String?

  // 渲染产物 / 外部文件
  pdfData          String? // 前端 jspdf 生成 base64,internal 必有,external 可空
  externalFileData String? // source='external' 时存上传的原 PDF base64

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([templateId])
  @@index([recipientUserId])
  @@index([revoked])
  @@index([issueDate])
  @@index([batchKey])
  @@index([source])
  @@index([certNo])
}
