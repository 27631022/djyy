# 开发/生产统一 PostgreSQL(2026-07-03 起,不再用 SQLite)
# 本地开发 = PG10 便携版(D:\web\pg10-portable,trust 认证);生产 = 群晖 postgres:16 容器(带密码)
DATABASE_URL="postgresql://djyy@localhost:5432/djyy?schema=public"

# 平台服务端口
PORT=3001

# 跨域允许的前端来源 (开发期 Vite 默认 5173)
CORS_ORIGIN="http://localhost:5173"

# JWT 签名密钥(生产环境必须设置)
# AUTH_SECRET="<long-random-string>"

# ─── 统一登录(Casdoor / 单位 SSO,标准 OIDC 授权码流)───
# AUTH_MODE: mock(默认,开发期点头像选账号)| oidc(统一登录,生产用)
AUTH_MODE="mock"
# oidc 模式必填四件套(Casdoor 后台「应用」页可查前两个;ISSUER=Casdoor 地址):
# OIDC_ISSUER="http://10.185.28.220:8000"
# OIDC_CLIENT_ID=""
# OIDC_CLIENT_SECRET=""
# OIDC_REDIRECT_URI="http://10.185.28.220:3001/api/auth/oidc/callback"
# IdP 账号平台没有对应用户时自动开通(建出来无角色,需管理员授权);默认关
# OIDC_JIT_CREATE="0"
# JIT 开通时「登录名」取哪个 claim:name(默认,契合 Casdoor)| preferred_username(标准 OIDC 的单位 SSO)
# OIDC_USERNAME_CLAIM="name"
# oidc 模式下仍放行 dev-login(内网兜底);默认关
# ALLOW_DEV_LOGIN="0"

# 证书管理 V2 · AI 提取(DeepSeek 大模型)
# 用户上传表彰文件(Word/PDF)→ AI 提取荣誉信息 → 预填发证表单 → 人工确认
# DEEPSEEK_API_KEY 留空时,/api/certificates/extract 返回友好错误「AI 服务未配置」
DEEPSEEK_API_KEY=""
DEEPSEEK_API_URL="https://api.deepseek.com/v1"
DEEPSEEK_MODEL="deepseek-chat"
DEEPSEEK_TIMEOUT_MS=30000

# 文件存储(storage 模块)
# STORAGE_DRIVER: local(默认) | synology | s3
#   local —— 本地磁盘;生产可把群晖共享盘挂载到后端机器后,把 STORAGE_LOCAL_DIR 指过去
#            (Linux SMB/NFS 挂载点、Windows \\NAS\djyy UNC、或后端跑在群晖 Docker 上的本地卷)
#   synology / s3 —— 占位驱动,启用前需先实现(见 plan 附录)
STORAGE_DRIVER="local"
STORAGE_LOCAL_DIR="./storage-data"
# 群晖 File Station API(STORAGE_DRIVER=synology 时;当前未实现)
# SYNOLOGY_BASE_URL="https://nas.example.com:5001"
# SYNOLOGY_ACCOUNT=""
# SYNOLOGY_PASSWD=""
# SYNOLOGY_SHARE="/djyy"
