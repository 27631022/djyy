{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "DjyyDesktop",
  "version": "0.2.6",
  "identifier": "party.djyy.desktop",
  "build": {
    "frontendDist": "../src"
  },
  "app": {
    "withGlobalTauri": true,
    "windows": [
      {
        "label": "main",
        "title": "党建益友",
        "url": "index.html",
        "width": 380,
        "height": 680,
        "resizable": true,
        "decorations": false,
        "transparent": true,
        "shadow": false
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "createUpdaterArtifacts": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "windows": {
      "nsis": {
        "installerHooks": "installer-hooks.nsh"
      }
    }
  },
  "plugins": {
    "updater": {
      "pubkey": "dW50cnVzdGVkIGNvbW1lbnQ6IG1pbmlzaWduIHB1YmxpYyBrZXk6IDQ5REJCODBGRjBFNDI4MjkKUldRcEtPVHdEN2piU2U5ZEp4aGxlUjJ1d2hrczVKNVp4VS9HVE1Cbm5xVE5SQUZvT3JaZ1owcXEK",
      "endpoints": ["http://127.0.0.1:3001/api/desktop/latest.json"],
      "dangerousInsecureTransportProtocol": true,
      "windows": { "installMode": "passive" }
    }
  }
}
