{
  "$schema": "../gen/schemas/desktop-schema.json",
  "identifier": "default",
  "description": "主窗口能力 —— 含加载的局域网 web 页(remote 白名单)可调通知。",
  "windows": ["main"],
  "remote": {
    "urls": ["http://*:5173", "http://*:3001", "http://localhost:5173"]
  },
  "permissions": [
    "core:default",
    "core:window:allow-set-always-on-bottom",
    "core:window:allow-set-skip-taskbar",
    "core:window:allow-start-dragging",
    "opener:default",
    "notification:default"
  ]
}
